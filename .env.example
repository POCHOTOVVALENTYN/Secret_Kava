# -----------------------------------------------------------------------------
# Enterprise Psychology Space Bot: Environment Variables Template
# Copy this file to '.env' and populate key credentials before bootup
# -----------------------------------------------------------------------------

# Environment Scoping (development / production / testing)
ENVIRONMENT=development
PROJECT_NAME="Psychological Space Bot"

# PostgreSQL Asyncpg DSN
DATABASE_URL=postgresql+asyncpg://postgres:secure_pg_pass@localhost:5432/psychology_db

# Redis Storage DSN
REDIS_URL=redis://:redis_secure_pass@localhost:6379/0

# Telegram Bot configuration
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFGGHHIIJJKKLLMMNNOOPPQQRR
TELEGRAM_WEBHOOK_SECRET=long_random_cryptographic_secret_string_here_12345!
# Set webhook url in production to route updates
# TELEGRAM_WEBHOOK_URL=https://bot.psychology-space.ua

# Monobank / LiqPay checkout tokens
MONOBANK_API_TOKEN=your_monobank_personal_token_here
MONOBANK_WEBHOOK_URL=https://bot.psychology-space.ua/api/v1/payments/monobank/callback
# LIQPAY_PUBLIC_KEY=your_liqpay_public_key
# LIQPAY_PRIVATE_KEY=your_liqpay_private_key

# Google OAuth Workspace API credentials (for Calendar slots and Sheets CRM)
GOOGLE_CLIENT_ID=google_client_id_hex_string.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=google_secret_token_key_here
GOOGLE_REFRESH_TOKEN=1//google_oauth_refresh_token_string_here
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_SHEET_ID=spreadsheet_document_key_here

# Security JWT Admin Dashboard Settings
JWT_SECRET_KEY=long_secret_hash_key_used_to_sign_dashboard_sessions_999!
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# GDPR clients data protection key
PII_ENCRYPTION_KEY=32_character_long_secret_key_123!
